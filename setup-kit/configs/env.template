# =============================================================
# OpenSpace environment — copy to ~/OpenSpace/openspace/.env
# =============================================================

# ---- Path B backbone LLM (OpenAI, per your choice) ----
OPENAI_API_KEY=sk-REPLACE_ME
OPENSPACE_MODEL=openai/gpt-4.1
# Alternates you can switch to without reinstalling:
#   openai/gpt-4o          (cheaper, fast)
#   openai/gpt-4.1-mini    (cheapest)
#   anthropic/claude-sonnet-4-5   (needs ANTHROPIC_API_KEY)
#   openrouter/qwen/qwen3.5-plus  (the benchmark config — needs OPENROUTER_API_KEY)

# ---- Cloud community (open-space.cloud) ----
# 1. Register at https://open-space.cloud
# 2. Paste the API key here — this is what enables shared evolution
#    across all your agents + the community skill registry.
OPENSPACE_API_KEY=os-REPLACE_ME

# ---- Shared workspace (single skill DB used by every agent) ----
# All 4 agents will point here, so evolution in Claude Code is
# instantly usable from Cursor / Codex / nanobot.
OPENSPACE_WORKSPACE=${HOME}/OpenSpace
OPENSPACE_HOST_SKILL_DIRS=${HOME}/.openspace/host_skills

# ---- Optional: remote backbone if you deploy to Railway ----
# OPENSPACE_REMOTE_URL=https://openspace-<yourapp>.up.railway.app/mcp
