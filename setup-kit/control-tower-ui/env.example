# ── Core API ────────────────────────────────────────────────
# When USE_MOCK=true, api.ts short-circuits and serves mock data.
# Flip to false once orchestrator is live.
NEXT_PUBLIC_USE_MOCK=true

# FastAPI orchestrator base URL
NEXT_PUBLIC_API_BASE=https://orchestrator.cleya.ai

# Personal dashboard — public bearer token is fine for now.
# Rotate in Render dashboard anytime.
NEXT_PUBLIC_API_TOKEN=

# ── Supabase Realtime (agents + tasks + memories + settings) ─
NEXT_PUBLIC_SUPABASE_URL=https://fhrynagbidbznfvuoxcn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-only secret (NOT exposed to browser) ──────────────
# Used by the /api/proxy route to inject auth server-side
CONTROL_TOWER_TOKEN=
